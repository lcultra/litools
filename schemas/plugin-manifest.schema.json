{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "litools plugin manifest",
  "type": "object",
  "required": ["id", "name", "version", "entry", "icon"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "entry": { "type": "string" },
    "icon": { "type": "string" },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "mode"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "mode": { "enum": ["instant", "view", "searchProvider"] }
        }
      }
    },
    "singleton": {
      "type": "boolean",
      "description": "单例模式。true 时全局仅一个运行时，重新打开会停靠；false 时允许创建多个实例。"
    },
    "permissions": { "type": "array", "items": { "type": "string" } }
  }
}
