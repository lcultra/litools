{
    "identifier": "core-webview",
    "description": "Core webview 及窗口的基础能力",
    "webviews": [
        "core-webview-*"
    ],
    "windows": [
        "main-window",
        "detach-window-*"
    ],
    "remote": {
        "urls": [
            "http://localhost:*"
        ]
    },
    "permissions": [
        "core:default",
        "core:event:allow-listen",
        "litools-core:default",
        "global-shortcut:default",
        "litools-sdk:default"
    ]
}
