{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "litools",
  "version": "0.1.0",
  "identifier": "dev.litools.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "litools",
        "width": 820,
        "height": 560,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
